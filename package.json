{
  "name": "@dokdosolutions/clover-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Clover POS — restaurant-focused AI integration by Dokdo Solutions",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "clover-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "jest --config jest.config.cjs",
    "test:sandbox": "tsx scripts/run-tests.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "bottleneck": "^2.19.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
